# =========================
# Server Configuration
# =========================
NODE_ENV=development
PORT=3000



# =========================
# Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# =========================
# Resend Configuration
# =========================
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=your_from_email
FROM_NAME=your_app_name
SUPPORT_EMAIL=your_support_email


# =========================
# JWT Secret
# =========================
JWT_SECRET=your_jwt_secret


# =========================
# CORS
# =========================
CORS_ORIGIN=http://localhost:5173


# =========================
# Supabase (Frontend - Vite)
# =========================
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key


# =========================
# Supabase (Backend)
# =========================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =========================
# AI Services
# =========================
AI_SERVICES_URL=http://localhost:8001
AI_INTERNAL_API_KEY=change-me-in-production

# Visual Damage Assessment (FastAPI) — backend proxies here; never expose to browser
# Example: http://localhost:8000
VDA_SERVICE_URL=http://localhost:8000
# Shared secret sent by backend as X-Service-Token to protect /assess
VDA_SERVICE_API_KEY=replace_with_shared_secret

# Optional: Groq API key for AI-ranked VDA service recommendations (same key as visual-damage-assessment works)
# If unset, recommendations fall back to keyword heuristics only.
GROQ_API_KEY=
# Optional override (Groq chat model id, e.g. llama-3.3-70b-versatile)
GROQ_SERVICE_MATCH_MODEL=openai/gpt-oss-20b
