# =========================
# Server Configuration
# =========================
NODE_ENV=development
PORT=3000



# =========================
# Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# =========================
# Resend Configuration
# =========================
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=your_from_email
FROM_NAME=your_app_name
SUPPORT_EMAIL=your_support_email


# =========================
# JWT Secret
# =========================
JWT_SECRET=your_jwt_secret


# =========================
# CORS
# =========================
CORS_ORIGIN=http://localhost:5173

# SUPABASE Configuration
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Backend auth + optional Postgres provider search (GET /providers/search)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# When true, provider search uses tables `providers` + `provider_categories` (PostgREST category filter via junction + .in)
SUPABASE_PROVIDER_SEARCH=false
