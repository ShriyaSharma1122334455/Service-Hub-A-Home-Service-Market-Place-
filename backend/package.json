{
  "name": "servicehub-backend",
  "version": "1.0.0",
  "description": "ServiceHub Backend API - Express.js + MongoDB",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "setup": "node src/scripts/setUpEnv.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node --coverage",
    "seed:categories": "node src/scripts/seedCategories.js",
    "seed:users": "node src/scripts/seedUsers.js",
    "seed:providers": "node src/scripts/seedProviders.js",
    "seed:all": "npm run seed:categories && npm run seed:users && npm run seed:providers",
    "lint": "eslint src"
  },
  "keywords": [
    "servicehub",
    "api",
    "express",
    "mongodb"
  ],
  "author": "Akash",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "resend": "^6.1.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^29.0.0",
    "jest-environment-node": "^29.7.0",
    "nodemon": "^3.1.11",
    "supabase": "^2.84.4",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
