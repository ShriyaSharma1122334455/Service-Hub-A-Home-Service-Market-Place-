# ── ServiceHub AI-Services — Environment Variables ────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit real values to version control.

# ── Service ───────────────────────────────────────────────────────────────
ENV=development
PORT=8001

# ── Google Cloud Vision (OCR) ─────────────────────────────────────────────
# Option A: path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=path to a service-account JSON file

# Option B: raw JSON string (useful for Docker / CI)
# GOOGLE_CREDENTIALS_JSON=

# ── AWS Rekognition (Face Matching) ───────────────────────────────────────
AWS_ACCESS_KEY_ID= "AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY= "AWS_SECRET_ACCESS_KEY"
AWS_REGION= "us-east-1"

# ── Cloudinary (image storage) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=CLOUDINARY_API_SECRET

# ── Internal Service Auth ────────────────────────────────────────────────
# Express backend sends this header so only it can call this service
INTERNAL_API_KEY=change-me-in-production

# ── Verification Thresholds ──────────────────────────────────────────────
FACE_MATCH_THRESHOLD=80.0

# Resend Configuration
RESEND_API_KEY=RESEND_API_KEY
FROM_EMAIL=noreply@servicehub.com
FROM_NAME=ServiceHub
SUPPORT_EMAIL=support@servicehub.com

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_at_least_32_characters_long

# CORS
CORS_ORIGIN=http://localhost:3000
# SUPABASE Configuration
VITE_SUPABASE_URL=CLOUDINARY_API_SECRET
VITE_SUPABASE_KEY=VITE_SUPABASE_KEY
VITE_SUPABASE_SERVICE_ROLE_KEY=VITE_SUPABASE_SERVICE_ROLE_KEY
VITE_SUPABASE_ANON_KEY=VITE_SUPABASE_ANON_KEY