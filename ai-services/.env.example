# ── ServiceHub AI-Services — Environment Variables ────────────────────────
# Copy this file to .env and fill in your credentials.
# NEVER commit real values to version control.

# ── Service ───────────────────────────────────────────────────────────────
ENV=development
PORT=8001

# ── Google Cloud Vision (OCR) ─────────────────────────────────────────────
# Option A: path to a service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: raw JSON string (useful for Docker / CI)
GOOGLE_CREDENTIALS_JSON=

# ── AWS Rekognition (Face Matching) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Cloudinary (image storage) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Internal Service Auth ────────────────────────────────────────────────
# Express backend sends this header so only it can call this service
INTERNAL_API_KEY=change-me-in-production

# ── Verification Thresholds ──────────────────────────────────────────────
FACE_MATCH_THRESHOLD=80.0

#BACKEND .env FILE
# ── Service Settings ──────────────────────────────────────────────────
ENV=development
PORT=8001
# Key required for Express backend to communicate with this service
INTERNAL_API_KEY=change-me-in-production 

# ── Google Cloud Vision (OCR) ─────────────────────────────────────────
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json
# Or provide the raw JSON string directly
GOOGLE_CREDENTIALS_JSON=

# ── AWS Rekognition (Face Matching) ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ── Verification Thresholds ───────────────────────────────────────────
# Minimum similarity required for a face match (0.0 to 100.0)
FACE_MATCH_THRESHOLD=80.0
