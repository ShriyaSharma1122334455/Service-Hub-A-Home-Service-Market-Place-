# Visual Damage Assessment API - Environment Configuration
# Copy this file to .env and fill in your actual values

# Groq API Key (Required)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Vision Model Selection (Optional)
# Available models: llama4-scout (default), llama4-maverick, llama3.2-11b, llama3.2-90b
# Default: llama4-scout (meta-llama/llama-4-scout-17b-16e-instruct)
# VDA_VISION_MODEL=llama4-scout

# Shared secret expected from backend via X-Service-Token header
VDA_SERVICE_API_KEY=replace_with_shared_secret

# Keep auth enabled in all environments unless explicitly debugging locally
VDA_REQUIRE_AUTH=true

# Optional browser origins for docs/testing UIs (comma-separated).
# Leave empty for backend-to-backend only traffic.
VDA_ALLOWED_ORIGINS=
