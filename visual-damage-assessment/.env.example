# Visual Damage Assessment API - Environment Configuration
# Copy this file to .env and fill in your actual values

# Google AI Studio / Gemini API key (required for Gemma 4 vision)
# Create a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vision model (optional)
# Short keys: gemma-4-26b-a4b (default), gemma-4-31b
# Or set a full API model id, e.g. gemma-4-26b-a4b-it
# VDA_VISION_MODEL=gemma-4-26b-a4b

# Shared secret expected from backend via X-Service-Token header
VDA_SERVICE_API_KEY=replace_with_shared_secret

# Keep auth enabled in all environments unless explicitly debugging locally
VDA_REQUIRE_AUTH=true

# Optional browser origins for docs/testing UIs (comma-separated).
# Leave empty for backend-to-backend only traffic.
VDA_ALLOWED_ORIGINS=
